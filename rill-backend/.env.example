# Public package/object IDs only. Rill Cloud never accepts a signing key.
# ACTIVE package: the v2 agent_wallet (has `agent_wallet::spend`). The current HTTP flows build
# manifest-less bindings (see F7) → the legacy spend() path → so the active package MUST be one that
# still exposes spend(). Keep this on v2 until the manifest-gated request_spend/confirm_spend flow is
# HTTP-wired; only then switch it to the redesigned package below.
AGENT_WALLET_PACKAGE_ID=0xd9265581b6b930f5fd27d9ec98e67b48f876f5de7bd25155639d808e9da636da
RILL_GUARD_PACKAGE_ID=0xadec99557cf7771bce94737fdd3ea0bcc989d81e0860f3e69af55433dae8c034

# STAGED — the redesigned agent_wallet (Rule + Hot Potato + version gate; scope rules off-chain),
# published to testnet 2026-07-19. NOT active yet: it has request_spend/confirm_spend instead of
# spend(), so it only works once the manifest-gated flow is HTTP-wired (F7) + the signer overhaul
# ships (coordination doc §7). Then set AGENT_WALLET_PACKAGE_ID to this and pass AGENT_WALLET_VERSION_ID.
# AGENT_WALLET_PACKAGE_ID_REDESIGNED=0xb02f39d682d0471344b1cc264f6f29d625280b9e73560d5beee3db3090563740
# AGENT_WALLET_VERSION_ID=0xd4f88a6dc271f923f0e55dd96eb8f8762ed4d45199c6719ae92365694478fd65
# AGENT_WALLET_OBJECT_ID=
# AGENT_CAP_OBJECT_ID=
# AGENT_WALLET_COIN_TYPE=0x2::sui::SUI
