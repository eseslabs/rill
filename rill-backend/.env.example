PORT=3002
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_MAINNET_RPC_URL=https://fullnode.mainnet.sui.io:443
PUBLIC_BASE_URL=https://api.rill.naisu.one
SIMULATE_SENDER=
SKILLS_STORE_PATH=./data/skills.json

# Public package/object IDs only. Rill Cloud never accepts a signing key.
# ACTIVE default package: the v2 agent_wallet (has `agent_wallet::spend`). A request whose
# `agentWallet` carries no `capabilityManifest` always resolves to THIS package and the legacy
# spend() call — unchanged, byte-identical to before F7.
AGENT_WALLET_PACKAGE_ID=0xd9265581b6b930f5fd27d9ec98e67b48f876f5de7bd25155639d808e9da636da
RILL_GUARD_PACKAGE_ID=0xadec99557cf7771bce94737fdd3ea0bcc989d81e0860f3e69af55433dae8c034

# WIRED (F7) — the redesigned agent_wallet (Rule + Hot Potato + version gate; scope rules
# off-chain), published to testnet 2026-07-19. A request whose `agentWallet.capabilityManifest` is
# set automatically resolves to THIS package (request_spend/prove/confirm_spend) + this Version
# object instead of v2's spend() — see `core/agent-wallet.ts`'s `normalizeAgentWallet`. Both
# packages coexist: which one a given request uses depends only on whether it supplies a
# capabilityManifest, never on a global toggle.
AGENT_WALLET_PACKAGE_ID_REDESIGNED=0xb02f39d682d0471344b1cc264f6f29d625280b9e73560d5beee3db3090563740
AGENT_WALLET_VERSION_ID=0xd4f88a6dc271f923f0e55dd96eb8f8762ed4d45199c6719ae92365694478fd65
# AGENT_WALLET_OBJECT_ID=
# AGENT_CAP_OBJECT_ID=
# AGENT_WALLET_COIN_TYPE=0x2::sui::SUI
